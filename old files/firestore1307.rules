rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // PAINEL DO TIME — regras existentes, inalteradas
    // ============================================================
    function isAuth() {
      return request.auth != null;
    }
    function profile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    function isGestor() {
      return isAuth() && profile().role == 'gestor';
    }
    function canManageTeam() {
      return isAuth() && (profile().role == 'gestor' || profile().canInviteMembers == true);
    }
    function canWrite() {
      return isAuth() && profile().role != 'visualizador';
    }
    match /profiles/{id} {
      allow read: if isAuth() && (request.auth.uid == id || canManageTeam());
      allow write: if isGestor() || request.auth.uid == id;
    }
    match /tasks/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /members/{id} { allow read: if isAuth(); allow write: if isGestor(); }
    match /messages/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /crm_companies/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /crm_proposals/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /crm_contracts/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /crm_visits/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /contracts_v2/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /projects_v1/{id} { allow read: if isAuth(); allow write: if canWrite(); }
    match /seguros_v1/{id} { allow read: if isAuth(); allow write: if canWrite(); }

    // ============================================================
    // GASTOS CORPORATIVOS SOS360 — Fase 5 (v2): login por e-mail/senha
    // ============================================================
    // Identidade real do Firebase Auth (uid estavel + e-mail verificado
    // criptograficamente). Funcoes otimizadas para o MINIMO de chamadas
    // get()/exists() por documento avaliado, ja que o Firestore impoe um
    // orcamento de leituras auxiliares por requisicao - com muitas chamadas
    // por documento, consultas em lista com varios itens podem estourar
    // esse orcamento e virar "permission-denied" mesmo com dados corretos.

    // Uma unica leitura do perfil (sem exists() separado). E seguro assumir
    // que todo uid autenticado de verdade tem um admin_users correspondente,
    // pois a conta so e criada pelo admin, que ja grava o perfil junto.
    function myProfile() {
      return get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data;
    }
    function isCompanyMember(companyId) {
      return isAuth() && myProfile().get('companyId', '') == companyId;
    }
    function isCompanyAdmin(companyId) {
      return isAuth() &&
        companyId is string &&
        exists(/databases/$(database)/documents/companies/$(companyId)) &&
        get(/databases/$(database)/documents/companies/$(companyId)).data.get('adminEmail', '') == request.auth.token.get('email', '');
    }

    // --- companies ---
    match /companies/{companyId} {
      allow read: if isCompanyAdmin(companyId);
      allow write: if false;
    }

    // --- admin_users: perfil real, doc ID = uid do Firebase Auth ---
    // A conta e criada diretamente pelo admin (via app secundario, sem
    // deslogar a propria sessao) + e-mail de definicao de senha do Firebase.
    match /admin_users/{uid} {
      allow read: if isAuth();
      allow create: if isCompanyAdmin(request.resource.data.get('companyId', ''));
      allow update: if isAuth() && request.auth.uid == uid;
      allow update: if isCompanyAdmin(resource.data.get('companyId', ''));
      allow delete: if isCompanyAdmin(resource.data.get('companyId', ''));
    }

    // --- cost_centers: centros de custo por empresa, geridos pelo admin ---
    // Leitura liberada para qualquer usuario autenticado - nomes de centro de
    // custo nao sao dado sensivel, e isso evita problemas de avaliacao de
    // regra em consultas de lista sobre colecoes vazias/pequenas. A escrita
    // continua restrita ao admin da propria empresa.
    match /cost_centers/{id} {
      allow read: if isAuth();
      allow create: if isCompanyAdmin(request.resource.data.get('companyId', ''));
      allow update, delete: if isCompanyAdmin(resource.data.get('companyId', ''));
    }

    // --- expenses: lancamentos corporativos ---
    // Duas regras "allow" separadas (em vez de um so || dentro da mesma
    // condicao) - o Firestore avalia cada allow em ordem e concede acesso
    // assim que uma delas permitir, sem precisar avaliar a seguinte.
    // Colocamos o caso mais comum (funcionario comum, 1 leitura auxiliar)
    // primeiro, e o caso raro (admin, 2 leituras auxiliares) depois.
    match /expenses/{id} {
      allow read: if isCompanyMember(resource.data.get('companyId', ''));
      allow read: if isCompanyAdmin(resource.data.get('companyId', ''));

      allow create: if isCompanyMember(request.resource.data.get('companyId', ''))
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isCompanyMember(resource.data.get('companyId', ''))
        && resource.data.get('userId', '') == request.auth.uid
        && resource.data.get('status', 'pending') == 'pending';
      allow update, delete: if isCompanyAdmin(resource.data.get('companyId', ''));
    }

    // --- expenses_personal: lancamentos do login Google (uso pessoal, sem empresa) ---
    match /expenses_personal/{id} {
      allow read: if isAuth() && resource.data.get('uid', '') == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.get('uid', '') == request.auth.uid
        && resource.data.get('status', 'pending') == 'pending';
    }
  }
}
